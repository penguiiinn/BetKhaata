---
interface Props {
  title?: string;
}

const { title = 'BetKhaata — Cricket Betting Intelligence' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="description" content="Track cricket bets, bankrolls, analytics, tournament ROI, risk discipline, and betting circles." />
    <meta name="theme-color" content="#0A0B0F" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://betkhaata.com/" />
    <meta property="og:title" content="BetKhaata — Cricket Betting Intelligence" />
    <meta property="og:description" content="Track cricket bets, bankrolls, analytics, tournament ROI, risk discipline, and betting circles." />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:site_name" content="BetKhaata" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://betkhaata.com/" />
    <meta name="twitter:title" content="BetKhaata — Cricket Betting Intelligence" />
    <meta name="twitter:description" content="Track cricket bets, bankrolls, analytics, tournament ROI, risk discipline, and betting circles." />
    <meta name="twitter:image" content="/og-image.png" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <style>
      /* Prevent FOUC */
      html {
        background: #0A0B0F;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
